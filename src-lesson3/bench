#!/usr/bin/env bash
# Run a script inside the containerized DuckDB (caged at 4 CPU / 8 GB, matching Postgres).
#
# Usage:
#   ./bench python load_postgres.py
#   ./bench python benchmark_queries.py
#   ./bench python experiment_point_query.py --iterations 100
#
# For the unconstrained "reveal" run (DuckDB on bare metal, all your cores/RAM):
#   uv run python <script>

set -euo pipefail

if [ $# -eq 0 ]; then
    echo "Usage: ./bench <command> [args...]" >&2
    echo "Example: ./bench python benchmark_queries.py" >&2
    exit 1
fi

exec docker compose exec duckdb "$@"
